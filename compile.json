{
  "$schema": "https://qooxdoo.org/schema/compile-1-0-0.json",
  "targets": [
    {
      "type": "source",
      "outputPath": "compiled/source",
      "application-types": ["node"],
      "babelOptions": {
        "targets": "node >= 18"
      }
    },
    {
      "type": "build",
      "outputPath": "compiled/build",
      "application-types": ["node"],
      "babelOptions": {
        "targets": "node >= 18"
      },
      "deployPath": "lib"
    }
  ],
  "defaultTarget": "source",
  "locales": ["en"],
  "libraries": ["."],
  "ignores": [
    "require.*",
    "process.*",
    "module.*",
    "__dirname",
    "__filename"
  ],
  "applications": [
    {
      "class": "qxl.lsp.Server",
      "name": "qxl.lsp",
      "type": "node",
      "include": []
    }
  ]
}
