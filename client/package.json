{
  "name": "qxl-lsp-client",
  "displayName": "Qooxdoo Language Support",
  "description": "Language support for Qooxdoo JavaScript projects",
  "version": "0.1.0",
  "publisher": "qooxdoo",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:javascript"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "javascript",
        "extensions": [".js"]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
